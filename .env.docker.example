# Variáveis usadas pelo docker compose (copie para .env na raiz do repositório)
# cp .env.docker.example .env

# URL pública do frontend (IP ou domínio do droplet, sem barra final)
CORS_ORIGIN=http://SEU_IP_OU_DOMINIO

# Deixe vazio para usar a mesma origem via nginx (/projects → api)
NEXT_PUBLIC_API_URL=

# Modelo baixado pelo Ollama na primeira subida (requer RAM suficiente no droplet)
OLLAMA_MODEL=llama3.2

# Porta HTTP exposta no host
HTTP_PORT=80
