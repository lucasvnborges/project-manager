# Porta em que a API sera iniciada
PORT=3001

# Conexao com o banco SQLite (arquivo local, criado pelo prisma migrate)
DATABASE_URL="file:./dev.db"

# Origem(ns) permitida(s) para CORS (frontend)
CORS_ORIGIN="http://localhost:3000"

# --- Analise com IA (GET /projects/:id/ai-analysis) ---
# Provedor usado pelo AiAnalysisModule: "openai" (real) ou "mock" (fallback sem custo/rede).
# Se OPENAI_API_KEY nao for informada, o modulo cai automaticamente para "mock".
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
