# Porta em que a API será iniciada
PORT=3001

# Conexão com o banco SQLite (arquivo local, criado pelo prisma migrate)
DATABASE_URL="file:./dev.db"

# Origem(ns) permitida(s) para CORS (frontend). Separe múltiplas origens com vírgula.
CORS_ORIGIN="http://localhost:3000"

# --- Análise com IA (GET /projects/:id/ai-analysis) ---
# Provedor: "ollama" (local via Ollama) ou "mock" (simulado, sem rede).
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
